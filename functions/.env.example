# Copy to .env and fill in real values. Never commit .env.

# Anthropic API key for AI writing feedback / reading analysis
CLAUDE_API_KEY=sk-ant-...

# Telegram bot used for test submission notifications
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=123456789

# Chat that receives dashboard feedback messages (defaults to TELEGRAM_CHAT_ID)
TELEGRAM_FEEDBACK_CHAT_ID=123456789

# Daily Plan reminder bot (@dailyplan_yes_bot)
DAILYPLAN_BOT_TOKEN=123456789:AA...
DAILYPLAN_WEBHOOK_SECRET=any-random-string
